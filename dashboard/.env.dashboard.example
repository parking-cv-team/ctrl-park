# --- Database (MySQL) ---
# Must point to the same DB instance that the processing pipeline writes to
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=park-db

# --- Calibration file paths ---
# Must match the paths used by the processing pipeline if running on the same machine
CALIBRATION_CONFIGS_DIR=calibration/configs
CALIBRATION_OUTPUT_DIR=calibration/output
