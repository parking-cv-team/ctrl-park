# --- Database (MySQL) ---
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=park-db

# --- Camera sources ---
# Comma-separated list of URIs (video files or RTSP streams).
# If only one camera, CAMERA_URI is also accepted as a fallback.
CAMERA_URIS=video/TestVideo.mp4
# CAMERA_URI=video/TestVideo.mp4

# --- Ingest / queue tuning ---
TARGET_FPS=3
MAX_QUEUE_SIZE=200
QUEUE_RESTART_THRESHOLD=100
SLEEP_TIME=1xq

# --- Worker / tracking tuning ---
FRAME_RATE=25
LOST_TRACK_BUFFER=30
MIN_DETECTION_SAVE_INTERVAL=1.0
BBOX_MOVEMENT_THRESHOLD=10
OCCUPANCY_TRANSITION_BUFFER_SECONDS=20
OCCUPANT_ABSENCE_THRESHOLD_SECONDS=120
OLD_DETECTION_CUTOFF_SECONDS=10

# --- Calibration file paths ---
CALIBRATION_CONFIGS_DIR=calibration/configs
CALIBRATION_OUTPUT_DIR=calibration/output

# --- Logging ---
USE_LOGGING=False
QUEUE_SIZE_LOG_PATH=queue_size.log
